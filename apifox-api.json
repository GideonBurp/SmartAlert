{
  "openapi": "3.0.3",
  "info": {
    "title": "SmartAlert API",
    "description": "SmartAlert 项目接口文档",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "本地开发环境"
    }
  ],
  "paths": {
    "/auth/sendCode": {
      "post": {
        "summary": "发送验证码",
        "description": "向指定手机号发送验证码，验证码有效期5分钟",
        "tags": ["认证模块"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendCodeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultVoid"
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "手机号验证码登录",
        "description": "使用手机号和验证码登录，未注册自动注册",
        "tags": ["认证模块"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultLogin"
                }
              }
            }
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "summary": "管理员注册",
        "description": "管理员账号注册，需要提供密码",
        "tags": ["认证模块"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultRegister"
                }
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "summary": "用户登出",
        "description": "退出登录，清除token",
        "tags": ["认证模块"],
        "security": [{"satoken": []}],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultVoid"
                }
              }
            }
          }
        }
      }
    },
    "/auth/isLogin": {
      "get": {
        "summary": "检查登录状态",
        "description": "检查当前是否已登录",
        "tags": ["认证模块"],
        "security": [{"satoken": []}],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultBoolean"
                }
              }
            }
          }
        }
      }
    },
    "/business/test/hello": {
      "get": {
        "summary": "测试接口",
        "description": "测试登录拦截功能",
        "tags": ["业务测试"],
        "security": [{"satoken": []}],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultString"
                }
              }
            }
          }
        }
      }
    },
    "/business/test/currentUser": {
      "get": {
        "summary": "获取当前用户信息",
        "description": "获取当前登录用户的详细信息",
        "tags": ["业务测试"],
        "security": [{"satoken": []}],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultCurrentUser"
                }
              }
            }
          }
        }
      }
    },
    "/business/test/sessionInfo": {
      "get": {
        "summary": "获取会话信息",
        "description": "获取Sa-Token会话相关信息",
        "tags": ["业务测试"],
        "security": [{"satoken": []}],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultSessionInfo"
                }
              }
            }
          }
        }
      }
    },
    "/business/test/checkPermission": {
      "get": {
        "summary": "检查权限",
        "description": "检查当前用户的角色和权限",
        "tags": ["业务测试"],
        "security": [{"satoken": []}],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultPermission"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "satoken": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Sa-Token认证，格式：satoken {token值}"
      }
    },
    "schemas": {
      "SendCodeRequest": {
        "type": "object",
        "required": ["telephone"],
        "properties": {
          "telephone": {
            "type": "string",
            "pattern": "^1[3-9]\\d{9}$",
            "example": "13800138000",
            "description": "手机号"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["telephone", "code"],
        "properties": {
          "telephone": {
            "type": "string",
            "pattern": "^1[3-9]\\d{9}$",
            "example": "13800138000",
            "description": "手机号"
          },
          "code": {
            "type": "string",
            "example": "123456",
            "description": "验证码"
          }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "required": ["username", "password", "telephone"],
        "properties": {
          "username": {
            "type": "string",
            "example": "admin",
            "description": "用户名"
          },
          "password": {
            "type": "string",
            "example": "admin123",
            "description": "密码"
          },
          "telephone": {
            "type": "string",
            "pattern": "^1[3-9]\\d{9}$",
            "example": "13800138000",
            "description": "手机号"
          },
          "email": {
            "type": "string",
            "example": "admin@example.com",
            "description": "邮箱"
          }
        }
      },
      "Result": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200,
            "description": "状态码"
          },
          "message": {
            "type": "string",
            "example": "success",
            "description": "消息"
          },
          "data": {
            "type": "object",
            "description": "数据"
          },
          "timestamp": {
            "type": "integer",
            "example": 1234567890,
            "description": "时间戳"
          }
        }
      },
      "ResultVoid": {
        "allOf": [
          {"$ref": "#/components/schemas/Result"},
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "null"
              }
            }
          }
        ]
      },
      "ResultBoolean": {
        "allOf": [
          {"$ref": "#/components/schemas/Result"},
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "boolean",
                "example": true
              }
            }
          }
        ]
      },
      "ResultString": {
        "allOf": [
          {"$ref": "#/components/schemas/Result"},
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "string",
                "example": "Hello, 这是一个需要登录才能访问的测试接口"
              }
            }
          }
        ]
      },
      "ResultLogin": {
        "allOf": [
          {"$ref": "#/components/schemas/Result"},
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "token": {
                    "type": "string",
                    "example": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                  },
                  "tokenName": {
                    "type": "string",
                    "example": "satoken"
                  }
                }
              }
            }
          }
        ]
      },
      "ResultRegister": {
        "allOf": [
          {"$ref": "#/components/schemas/Result"},
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "userId": {
                    "type": "integer",
                    "example": 1
                  },
                  "message": {
                    "type": "string",
                    "example": "注册成功"
                  }
                }
              }
            }
          }
        ]
      },
      "ResultCurrentUser": {
        "allOf": [
          {"$ref": "#/components/schemas/Result"},
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "loginId": {
                    "type": "integer",
                    "example": 1
                  },
                  "token": {
                    "type": "string",
                    "example": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                  },
                  "user": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          }
        ]
      },
      "ResultSessionInfo": {
        "allOf": [
          {"$ref": "#/components/schemas/Result"},
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "loginId": {
                    "type": "integer",
                    "example": 1
                  },
                  "loginType": {
                    "type": "string",
                    "example": "login"
                  },
                  "tokenValue": {
                    "type": "string",
                    "example": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                  },
                  "tokenTimeout": {
                    "type": "integer",
                    "example": 2592000
                  },
                  "isLogin": {
                    "type": "boolean",
                    "example": true
                  }
                }
              }
            }
          }
        ]
      },
      "ResultPermission": {
        "allOf": [
          {"$ref": "#/components/schemas/Result"},
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "hasRole": {
                    "type": "boolean",
                    "example": false
                  },
                  "hasPermission": {
                    "type": "boolean",
                    "example": true
                  },
                  "permissionList": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "example": ["BASIC"]
                  },
                  "roleList": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "example": ["CUSTOMER"]
                  }
                }
              }
            }
          }
        ]
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "username": {
            "type": "string",
            "example": "user_8000"
          },
          "telephone": {
            "type": "string",
            "example": "13800138000"
          },
          "email": {
            "type": "string",
            "example": null
          },
          "nickname": {
            "type": "string",
            "example": "用户8000"
          },
          "avatar": {
            "type": "string",
            "example": null
          },
          "state": {
            "type": "string",
            "example": "INIT"
          },
          "userRole": {
            "type": "string",
            "example": "CUSTOMER"
          },
          "inviteCode": {
            "type": "string",
            "example": "ABC12345"
          },
          "certification": {
            "type": "boolean",
            "example": false
          },
          "createTime": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T12:00:00"
          },
          "updateTime": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T12:00:00"
          }
        }
      }
    }
  }
}
